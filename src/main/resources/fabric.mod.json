{
	"schemaVersion": 1,
	"id": "dirtunjoyer",
	"version": "${version}",
	"name": "Dirt Unjoyer",
	"description": "25w14craftmine mod that lets you freely enable/disable (hopefully) all unlocks/upgrades.",
	"authors": [
		"ChainSwordCS"
	],
	"contact": {
		"homepage": "https://github.com/ChainSwordCS/dirtunjoyer",
		"sources": "https://github.com/ChainSwordCS/dirtunjoyer"
	},
	"license": "MIT",
	"icon": "assets/dirtunjoyer/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.chainswordcs.dirtunjoyer.ExampleMod"
		],
		"client": [
			"com.chainswordcs.dirtunjoyer.ExampleModClient"
		]
	},
	"mixins": [
		"dirtunjoyer.mixins.json",
		{
			"config": "dirtunjoyer.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.12",
		"minecraft": "1.21.6-alpha.25.14.craftmine",
		"java": ">=21"
	},
	"suggests": {
		"fabric-api": "*"
	}
}